{
	"$schema": "https://opencode.ai/config.json",
	"theme": "catppuccin-macchiato",
	"model": "anthropic/claude-opus-4-6",
	"small_model": "anthropic/claude-haiku-4-5",
	"share": "disabled",
	"autoshare": false,
	"autoupdate": true,
	"instructions": ["AGENTS.md"],
	"permission": {
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "deny",
			"*.aws*": "deny",
			"*.ssh*": "deny"
		},
		"bash": {
			"*.env": "deny",
			"*.env.example": "deny",
			"*.aws*": "deny",
			"*.ssh*": "deny"
		}
	},
	"agent": {
		"code-analyzer": {
			"disable": true
		},
		"general": {
			"disable": true
		},
		"explore": {
      "model": "anthropic/claude-sonnet-4-5"
    },
		"plan": {
			"permission": {
				"bash": {
					"find *": "allow",
					"ls *": "allow",
					"grep *": "allow"
				}
			}
		},
		"build": {
			"model": "anthropic/claude-sonnet-4-5"
		},
    "compaction": {
      "model": "anthropic/claude-sonnet-4-5"
    },
	},
	"mcp": {
		"github": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN",
				"ghcr.io/github/github-mcp-server"
			],
			"enabled": false,
			"environment": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
			}
		},
		"chrome-devtools": {
			"type": "local",
			"command": ["npx", "chrome-devtools-mcp@latest"],
			"enabled": false
		},
		"querypie": {
			"type": "local",
			"command": [
				"uv",
				"run",
				"--directory",
				"/Users/charles/Desktop/src/querypie-mcp",
				"querypie-mcp"
			],
			"enabled": false,
			"environment": {
				"DB_PROD_HOST": "10.0.45.235",
				"DB_PROD_USER": "pr69a229cb-c6df-42ab-a2e3-ceb2e144e328",
				"DB_PROD_PASSWORD": "{env:QUERYPIE_PASSWORD}",
				"DB_PROD_NAME": "lemonbase",
				"DB_LOCAL_HOST": "127.0.0.1",
				"DB_LOCAL_PORT": "3306",
				"DB_LOCAL_USER": "root",
				"DB_LOCAL_PASSWORD": "rootpw",
				"DB_LOCAL_NAME": "lemonbase_temp"
			}
		},
		"serena": {
			"type": "local",
			"command": [
				"uvx",
				"--from",
				"git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--open-web-dashboard=false"
			],
			"enabled": true
		},
		"": {
			"type": "local",
			"command": ["npx", "-y", "@playwriter/install-mcp playwriter@latest"],
			"enabled": false
		}
	}
}
